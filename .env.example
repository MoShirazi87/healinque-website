# ==============================================================================
# HEALINQUE WEBSITE - ENVIRONMENT VARIABLES
# ==============================================================================
# Copy this file to .env.local and fill in the values before deployment.
# Do NOT commit .env.local to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# SHOPIFY INTEGRATION
# ------------------------------------------------------------------------------
# Get these from your Shopify admin: Settings > Apps > Develop apps

# Your Shopify store domain (e.g., healinque.myshopify.com)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Storefront API access token (for public product/cart access)
# Create under: Settings > Apps > Develop apps > Create app > Configure Storefront API scopes
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Admin API access token (for customer management)
# Create under: Settings > Apps > Develop apps > Create app > Configure Admin API scopes
# Required scopes: read_customers, write_customers
SHOPIFY_ADMIN_ACCESS_TOKEN=

# Webhook secret for verifying Shopify order webhooks
# Found under: Settings > Notifications > Webhooks
SHOPIFY_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# HEALTHIE INTEGRATION (Patient Portal & Booking)
# ------------------------------------------------------------------------------
# Get these from your Healthie admin dashboard

# Healthie GraphQL API URL
HEALTHIE_API_URL=https://api.gethealthie.com/graphql

# Healthie API Key
# Found under: Settings > Developer > API Keys
HEALTHIE_API_KEY=

# Healthie Organization ID (optional, for multi-org setups)
HEALTHIE_ORG_ID=

# ------------------------------------------------------------------------------
# AUTHENTICATION SECRETS
# ------------------------------------------------------------------------------
# Used for encrypting session tokens - generate a random 32+ character string

# Secret for encrypting auth cookies
AUTH_SECRET=your-random-secret-key-min-32-chars

# ------------------------------------------------------------------------------
# OPTIONAL: ANALYTICS & TRACKING
# ------------------------------------------------------------------------------

# Google Analytics 4 Measurement ID (e.g., G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Tag Manager Container ID (e.g., GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Facebook Pixel ID
NEXT_PUBLIC_FB_PIXEL_ID=

# ------------------------------------------------------------------------------
# FORM HANDLING & EMAIL
# ------------------------------------------------------------------------------

# Email address that receives all form submissions (contact, consultation, newsletter)
CONTACT_FORM_RECIPIENT=AzadehMD@gmail.com

# Sender email address (must be verified with your email service)
EMAIL_FROM=noreply@healinque.com

# Email service — choose ONE (Resend recommended for simplicity)
# Resend: Get API key at https://resend.com/api-keys
RESEND_API_KEY=

# SendGrid: Get API key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# ------------------------------------------------------------------------------
# PABAU INTEGRATION (Practice Management & Online Booking)
# ------------------------------------------------------------------------------
# Get these from Pabau: Settings → Integrations → API

# Your Pabau company slug (from your booking URL, e.g., "healinque")
NEXT_PUBLIC_PABAU_COMPANY_SLUG=

# Pabau API key (for server-side patient creation and appointment sync)
PABAU_API_KEY=

# Pabau API base URL (default: https://api.pabau.com)
# PABAU_API_URL=https://api.pabau.com

# ------------------------------------------------------------------------------
# GOOGLE MAPS
# ------------------------------------------------------------------------------

# Google Maps Embed API key (for contact page map)
# Get at: https://console.cloud.google.com/apis/credentials
# Restrict to Maps Embed API + your domain
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ------------------------------------------------------------------------------
# DEPLOYMENT NOTES
# ------------------------------------------------------------------------------
# 1. For Vercel: Add these in the Environment Variables section of your project settings
# 2. For local development: Copy to .env.local
# 3. Never commit actual values to version control
# 4. Use Vercel's environment variable groups for staging vs production

# ==============================================================================
